{
    "compilerOptions": {
        "outDir": "dist",
        "noEmit": true,
        "target": "es2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "verbatimModuleSyntax": false,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "stripInternal": true,
        "isolatedModules": true,
        "paths": {
            "rpc-websockets": ["./node_modules/rpc-websockets/dist/index.d.ts"]
        }
    }
}
